# --- تنظیمات محیط پایتون ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- دیتابیس‌ها و فایل‌های دیتای حجیم ---
# دیتابیس روی PostgreSQL ابری است؛ فایل‌های SQLite محلی نباید در گیت باشند.
data/*.db
*.sqlite
*.sqlite3

# --- باینری‌های حجیم ---
*.deb

# --- محیط‌های مجازی و تنظیمات سیستم ---
venv/
env/
.env
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- فایل‌های حساس و هوش مصنوعی ---
# مدل‌ها نباید به صورت باینریِ حجیم در گیت‌هابِ عمومی باشند 
# اما اگر ریپازیتوری شما خصوصی است، می‌توانید این خط را غیرفعال کنید
src/models/*.pkl

# --- خروجی‌های موقت و آرشیوها ---
# backtest_summary.txt
all_project_files.txt
*.log
