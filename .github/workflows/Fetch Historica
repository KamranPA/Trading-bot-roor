    - name: Fetch Historical Market Data
      run: |
        set -e  # اگر اسکریپت خطا داشت، ورک‌فلو را متوقف کن
        echo "Creating directory..."
        mkdir -p data/historical
        echo "Running fetcher..."
        if [ -f "src/fetcher.py" ]; then 
            python src/fetcher.py
        elif [ -f "fetcher.py" ]; then 
            python fetcher.py
        else
            echo "❌ Error: fetcher.py not found!"
            exit 1
        fi
        echo "Directory contents after fetch:"
        ls -la data/historical
